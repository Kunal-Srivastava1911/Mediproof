# Copy to .env (gitignored). Never commit real keys.

# LLM
GEMINI_API_KEY=
LLM_LIVE=0                 # 1 = allow live LLM calls; 0 = replay from fixtures only
LLM_BUDGET_USD=1.00        # hard cap; client stops and logs when exceeded
LLM_MODEL=gemini-1.5-flash

# Datagen
DATAGEN_SEED=42

# Storage
DATABASE_URL=sqlite:///./data/mediproof.db
